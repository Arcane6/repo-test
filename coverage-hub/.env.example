# Copie este arquivo para ".env" (não versionado) e preencha com os
# valores reais. Nenhuma dessas variáveis tem valor padrão em código —
# se faltar uma obrigatória, o app não sobe.

# --- Oracle (obrigatório — o portal inteiro depende disso) ----------------
ORACLE_USER=
ORACLE_PASSWORD=
# DSN no formato host:porta/service_name (ex.: oracle-prod.tim.com.br:1521/NTWPRD)
ORACLE_DSN=
# Só preencher se precisar do modo "thick" do oracledb (Oracle Instant
# Client instalado à parte). Deixe em branco para usar o modo "thin"
# padrão, que não exige nada instalado no sistema.
ORACLE_CLIENT_LIB_DIR=

# --- BigQuery (opcional — nenhuma feature usa ainda, só fica pronto) -------
# Caminho para o arquivo JSON de uma service account do GCP com permissão
# de leitura no(s) dataset(s) que for consultar. Essa variável é lida
# direto pela biblioteca do Google (google-auth), não por config/settings.py.
GOOGLE_APPLICATION_CREDENTIALS=
# ID do projeto GCP. Pode deixar em branco — a lib tenta inferir a partir
# da credencial acima; só preencha se precisar apontar para um projeto
# diferente do da service account.
BIGQUERY_PROJECT=
